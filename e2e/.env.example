# Copy to e2e/.env and adjust for your Docker dev instance.
BASE_URL=http://localhost:8081
E2E_LOGIN_URL=${BASE_URL}/index.php/login

E2E_USER=admin
E2E_PASS=your-dev-password

# Optional: reuse cookies after `npm run e2e:auth`
# E2E_STORAGE_STATE=/absolute/path/to/apps/projectcheck/.auth/storage-state.json

E2E_DASHBOARD_URL=${BASE_URL}/index.php/apps/projectcheck/dashboard
E2E_PROJECTS_URL=${BASE_URL}/index.php/apps/projectcheck/projects
E2E_PROJECT_CREATE_URL=${BASE_URL}/index.php/apps/projectcheck/projects/create
E2E_TIME_ENTRY_CREATE_URL=${BASE_URL}/index.php/apps/projectcheck/time-entries/create
# App-specific name — avoid generic E2E_SETTINGS_URL (TicketCheck uses the same name).
E2E_PROJECTCHECK_SETTINGS_URL=${BASE_URL}/index.php/apps/projectcheck/settings
