{
	"name": "aSoftwareByDesignRepository/nextcloud-projectcheck",
	"description": "IT project management with time tracking and budget control",
	"type": "library",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "Alexander Mäule",
			"email": "info@software-by-design.de"
		}
	],
	"require": {
		"php": ">=8.1",
		"nextcloud/ocp": "^25.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.5",
		"phpstan/phpstan": "^1.0",
		"nextcloud/coding-standard": "^5.0"
	},
	"autoload": {
		"psr-4": {
			"OCA\\ProjectCheck\\": "lib/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"OCA\\ProjectCheck\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"test:unit": "phpunit --testsuite=unit",
		"test:integration": "phpunit --testsuite=integration",
		"test:acceptance": "phpunit --testsuite=acceptance",
		"phpstan": "phpstan analyse",
		"cs:check": "phpcs",
		"cs:fix": "phpcbf"
	},
	"config": {
		"optimize-autoloader": true,
		"sort-packages": true
	}
}