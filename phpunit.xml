<?xml version="1.0" encoding="utf-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.3/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         verbose="true">
    <testsuites>
        <testsuite name="unit">
            <directory suffix="Test.php">tests/Unit/AppInfo</directory>
            <directory suffix="Test.php">tests/Unit/Controller</directory>
            <directory suffix="Test.php">tests/Unit/Listener</directory>
            <directory suffix="Test.php">tests/Unit/Middleware</directory>
            <directory suffix="Test.php">tests/Unit/Util</directory>
            <directory suffix="Test.php">tests/Unit/Db</directory>
            <directory suffix="Test.php">tests/Unit/Migration</directory>
            <directory suffix="Test.php">tests/Unit/Service</directory>
            <directory suffix="Test.php">tests/Unit/Repair</directory>
            <file>tests/Unit/Controller/TimeEntryControllerTest.php</file>
            <file>tests/Unit/Controller/ProjectFileControllerTest.php</file>
        </testsuite>
        <testsuite name="integration">
            <directory suffix="Test.php">tests/Integration</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">lib</directory>
        </include>
        <exclude>
            <directory suffix=".php">lib/Migration</directory>
        </exclude>
        <report>
            <html outputDirectory="tests/coverage" lowUpperBound="35" highLowerBound="70"/>
        </report>
    </coverage>

    <logging>
        <junit outputFile="tests/results.xml"/>
    </logging>
</phpunit>
